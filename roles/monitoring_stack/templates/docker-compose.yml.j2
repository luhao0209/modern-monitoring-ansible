version: '3.8'

services:
  prometheus:
    image: dockerpull.com/prom/prometheus:latest
    container_name: prometheus
    volumes:
      - {{ install_root }}/prometheus/prometheus.yml:/etc/prometheus/prometheus.yml
      - {{ install_root }}/prometheus/alert_rules.yml:/etc/prometheus/alert_rules.yml
      - prometheus_data:/prometheus
    command:
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--storage.tsdb.retention.time=15d'
    ports:
      - "9090:9090"
    restart: unless-stopped

  alertmanager:
    image: dockerpull.com/prom/alertmanager:latest
    container_name: alertmanager
    volumes:
      - {{ install_root }}/alertmanager/alertmanager.yml:/etc/alertmanager/alertmanager.yml
    ports:
      - "9093:9093"
    restart: unless-stopped

  grafana:
    image: dockerpull.com/grafana/grafana:latest
    container_name: grafana
    volumes:
      - grafana_data:/var/lib/grafana
    ports:
      - "3000:3000"
    restart: unless-stopped

  node-exporter:
    image: dockerpull.com/prom/node-exporter:latest
    container_name: node-exporter
    volumes:
      - /proc:/host/proc:ro
      - /sys:/host/sys:ro
      - /:/rootfs:ro
    command:
      - '--path.procfs=/host/proc'
      - '--path.rootfs=/rootfs'
      - '--path.sysfs=/host/sys'
    ports:
      - "9100:9100"
    restart: unless-stopped

  custom-exporter:
    # 这里的 build context 指向远程服务器上的路径
    build: {{ install_root }}/custom-exporter
    container_name: custom-exporter
    pid: host
    volumes:
      - /:/host:ro,rslave
    ports:
      - "{{ exporter_port }}:8000"
    restart: always

volumes:
  prometheus_data:
  grafana_data:
